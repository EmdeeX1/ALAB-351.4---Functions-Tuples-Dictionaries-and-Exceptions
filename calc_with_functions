def add_two_numbers(a, b):
    " " "Returns the sum of two numbers" " "
    return a + b
def subtract_two_numbers(a, b):
    " " "Returns the difference of two numbers" " "
    return a - b
def multiply_two_numbers(a, b):
    " " "Returns the product of two numbers" " "
    return a * b
def divide_two_numbers(a, b):
    " " "Returns the quotient of two numbers" " "
    if b == 0:
        raise ZeroDivisionError("Denominator cannot be zero.")
    return a / b
def calculate (a, b, operation):
    " " "Performs the specified operation on two numbers" " "
    if operation == 'add':
        return add_two_numbers(a, b)
    elif operation == 'subtract':
        return subtract_two_numbers(a, b)
    elif operation == 'multiply':
        return multiply_two_numbers(a, b)
    elif operation == 'divide':
        return divide_two_numbers(a, b)
    else:
        raise ValueError("Invalid operation. Choose from 'add', 'subtract', 'multiply', or 'divide'.")
def main():
    try:
        a = float(input("Enter the first number: "))
        b = float(input("Enter the second number: "))
        operation = input("Enter the operation (add, subtract, multiply, divide): ")
        result = calculate(a, b, operation)
        print(f"The result is: {result}")
    except ValueError as e:
        print(f"Error: {e}")
        print("Please enter valid numbers or a valid operation.")
    except ZeroDivisionError as e:
        print(f"Error: {e}")
    except Exception as e:
        print(f"An unexpected error occurred: {{e}}")
if __name__ == "__main__":
    main()