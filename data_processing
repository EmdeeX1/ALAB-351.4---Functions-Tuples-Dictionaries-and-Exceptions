# Define a dictionary course_grades where keys are course names: Math, Science, and History
def course_grades():
 grades = {
   "Math": (90, 40, 50),
   "Science": (86, 70),
   # The intentional edge case
   "History": ()
 }
 for course, grades_tuples in grades.items():
       try:
         avg = get_average_grade(grades_tuples)
               # Gracefully handle None return values (for example, from empty tuples) 
         if avg is None:
               print(f"Warning: No grade found for {course}.")
         else:
                 print(f"The average grade for {course} is {avg:.1f}")
       except Exception as u:
         print(f"An error occurred processing {course}: {u}")
             
course_grades()