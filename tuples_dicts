# 1. Create a tuple with the names of the months
months = ("January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December")
# 2. Print the first and last month
print(f"First month: {months[0]}, Last month: {months[-1]}")
# 3. Demonstrate that tuples are immutable using try/except block
try:
    months[0] = "New Month"
except TypeError as e:
    print(f"Error: {e}")
    #print((f"Error: {{e}}"))
    print("Tuples are immutable and cannot be changed after creation.")
